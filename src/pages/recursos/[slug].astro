---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/ui/Section.astro";
import { resources } from "../../data/recursos.data";
import type { Resource } from "../../types/recursos.type";

import ResourceContent from "../../components/recursos/details/ResourceContent.astro";
import ResourceSidebar from "../../components/recursos/details/ResourceSidebar.astro";
import RelatedResources from "../../components/recursos/details/RelatedResources.astro";
import ContactSection from "../../components/home/ContactSection.astro";

// Generar rutas estáticas para cada recurso
export async function getStaticPaths() {
  return resources.map((resource) => ({
    params: { slug: resource.slug },
    props: { resource },
  }));
}

interface Props {
  resource: Resource;
}

const { resource } = Astro.props;
---

<Layout title={resource.title} description={resource.description}>
  <Section class="py-12 md:py-20 lg:py-24">
    <!-- Grid Layout 2 Columnas -->
    <div class="grid lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start max-w-7xl mx-auto">
      
      <!-- Columna Principal Izquierda -->
      <main class="w-full">
        <ResourceContent resource={resource} />
      </main>

      <!-- Columna Derecha Sticky -->
      <aside class="w-full">
        <div class="sticky top-32">
          <ResourceSidebar resource={resource} />
        </div>
      </aside>

    </div>
  </Section>

  <RelatedResources resource={resource} />
  
  <ContactSection />
</Layout>

---
import HeroSection from "../../components/recursos/HeroSection.astro";
import ContactSection from "../../components/home/ContactSection.astro";
import ResourceCard from "../../components/recursos/ResourceCard.astro";
import Section from "../../components/ui/Section.astro";
import { resources } from "../../data/recursos.data";
import Layout from "../../layouts/Layout.astro";
---

<Layout 
  title="Blog y Recursos" 
  description="Artículos, guías y contenido exclusivo de IESL Institute para potenciar tu desarrollo profesional y personal."
>
  <HeroSection />

  <Section class="py-16 md:py-24 bg-gray-50/20">
    <div class="max-w-7xl mx-auto mb-12">
      <h2 class="font-bold text-gray-900 tracking-tight">Últimos artículos</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {resources.map((resource) => (
        <ResourceCard resource={resource} />
      ))}
    </div>
  </Section>

  <ContactSection />
</Layout>

---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/home/HeroSection.astro";
import AboutSection from "../components/home/AboutSection.astro";
import CoursesSection from "../components/home/CoursesSection.astro";
import CommunitySection from "../components/home/CommunitySection.astro";
import WellnessSection from "../components/home/WellnessSection.astro";
import CertificationsSection from "../components/shared/CertificationsSection.astro";
import TestimonialsSection from "../components/shared/TestimonialsSection.astro";
import { testimonials } from "../data/inicio.data";
import FaqSection from "../components/home/FaqSection.astro";
import ContactSection from "../components/home/ContactSection.astro"; 
---

<Layout 
  title="Inicio" 
  description="IESL Institute - Crecimiento profesional con enfoque humano. Estudia, crece y conecta con nuestra comunidad y beneficios pensados para vos."
>
  <HeroSection />
  <AboutSection />
  <CoursesSection />
  <CommunitySection />
  <WellnessSection />
  <CertificationsSection />
  <TestimonialsSection testimonials={testimonials} />
  <FaqSection />
  <ContactSection />
</Layout>

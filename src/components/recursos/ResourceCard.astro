---
import type { Resource } from "../../types/recursos.type";
import { Icon } from "astro-icon/components";

interface Props {
  resource: Resource;
}
const { resource } = Astro.props;
---
<a href={`/recursos/${resource.slug}`} class="bg-white rounded-3xl border border-gray-200 p-4 object-cover flex flex-col h-full hover:shadow-xl hover:border-primary/20 transition-global group cursor-pointer text-left">
  
  <!-- Badge categoría -->
  <div class="mb-5">
    <span class="inline-flex items-center border border-gray-200 text-gray-500 text-xs font-inter px-3 py-1 rounded-full bg-white">
      {resource.category}
    </span>
  </div>
  
  <h3 class="font-bold text-gray-900 text-[22px] mb-4 leading-tight group-hover:text-primary transition-global decoration-2 underline-offset-4 pointer-events-none">
    {resource.title}
  </h3>
  
  <p class="text-gray-500 text-sm mb-6 flex-1 leading-relaxed pointer-events-none">
    {resource.description}
  </p>

  {resource.includedResource && (
    <div class="rounded-2xl mb-6 flex items-start gap-4 pointer-events-none">
      <div class="bg-primary/10 text-primary p-2.5 rounded-xl shrink-0">
        <Icon name={resource.includedResource.icon || "material-symbols:download-rounded"} class="text-xl" />
      </div>
      <div>
        <p class="text-[11px] text-gray-500 font-bold uppercase tracking-wider mb-1">
          Recurso incluido
        </p>
        <p class="text-sm font-bold text-gray-900 leading-tight">
          {resource.includedResource.label}
        </p>
      </div>
    </div>
  )}

  <div class="flex justify-end mt-auto pt-2">
    <span class="text-primary font-bold text-sm flex items-center gap-1.5 group-hover:gap-2 transition-all">
      Leer artículo
      <Icon name="fluent:arrow-right-16-filled" size={24} />
    </span>
  </div>
</a>

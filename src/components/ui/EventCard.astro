---
import DateBubble from "./DateBubble.astro";

interface Props {
  title: string;
  description: string;
  date: string;
}

const { title, description, date } = Astro.props;
---

<div class="card-base transition-global flex gap-4 p-4">
  <DateBubble date={date} />
  <div class="flex flex-col justify-between">
    <h5 class="font-bold text-gray-900 leading-tight mb-1">{title}</h5>
    <p class="text-gray-500 leading-relaxed">{description}</p>
  </div>
</div>

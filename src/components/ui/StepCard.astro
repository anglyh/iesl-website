---

interface Props {
  step: number;
  title: string;
  description: string;
}

const { step, title, description } = Astro.props;
const stepNumber = String(step).padStart(2, "0")
---

<div class="flex flex-col items-center text-center group">
  <div class="mb-6 bg-primary/10 w-18 h-18 rounded-full flex items-center justify-center border border-primary">
    <span class="text-primary text-3xl font-bold font-inter">{stepNumber}</span>
  </div>
  <h3 class="font-bold text-gray-900 mb-4 text-lg">{title}</h3>
  <p class="text-gray-600 leading-relaxed max-w-80">{description}</p>
</div>

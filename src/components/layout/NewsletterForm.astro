---
import { Icon } from "astro-icon/components";
---

<div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8">
  <div class="max-w-md xl:max-w-xl">
    <h3 class="font-poppins font-bold text-white text-[28px] md:text-[32px] leading-tight mb-3 tracking-tight">Suscríbete a nuestro Newsletter</h3>
    <p class="font-inter text-gray-300 text-sm md:text-base">Recibe invitaciones a workshops, eventos y acceso anticipado a nuevos cursos.</p>
  </div>
  
  <div class="w-full md:w-auto flex flex-col gap-3">
    <span class="text-gray-400 text-xs font-inter ml-1">Sin spam. Solo contenido que realmente te suma.</span>
    <form class="flex w-full sm:w-[380px] md:w-[420px] gap-3">
      <input 
        type="email" 
        placeholder="tu@email.com" 
        class="flex-1 px-6 py-3.5 rounded-full bg-white border-transparent text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary font-inter text-sm placeholder-gray-400" 
        required
      />
      <button 
        type="submit" 
        class="bg-primary text-white w-12 h-12 shrink-0 rounded-full flex items-center justify-center hover:bg-primary/90 transition-global cursor-pointer"
        aria-label="Suscribirse"
      >
        <Icon name="fluent:arrow-right-16-filled" class="text-xl" />
      </button>
    </form>
  </div>
</div>

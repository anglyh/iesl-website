---
import { Icon } from "astro-icon/components";
import { ROUTES } from "../../constants/routes";
import Button from "../ui/Button.astro";
---

<!-- Overlay base for the menu -->
<div id="mobile-menu-overlay" class="md:hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-40 opacity-0 invisible transition-all duration-300"></div>

<!-- Sidebar Menu -->
<aside id="mobile-menu" class="md:hidden fixed top-0 right-0 w-[300px] h-full bg-white shadow-2xl z-50 translate-x-full transition-transform duration-300 flex flex-col">
  <div class="p-6 flex justify-between items-center border-b border-gray-100">
    <span class="font-bold text-gray-900 text-lg">Menú principal</span>
    <button id="close-menu" class="text-gray-500 hover:text-primary transition-colors p-2 -mr-2 cursor-pointer">
      <Icon name="mdi:close" class="text-2xl" />
    </button>
  </div>
  
  <nav class="flex-1 overflow-y-auto p-6 flex flex-col gap-6 text-[15px] font-medium text-gray-800">
    <a href={ROUTES.HOME} class="hover:text-primary transition-colors">Inicio</a>
    
    <!-- Accordion for Cursos -->
    <details class="group">
      <summary class="flex items-center justify-between cursor-pointer hover:text-primary transition-colors list-none">
        Cursos
        <Icon name="mdi:chevron-down" class="text-xl text-gray-500 group-open:-rotate-180 transition-transform" />
      </summary>
      <div class="flex flex-col gap-4 mt-4 pl-4 border-l-2 border-primary/20 text-gray-600">
        <a href={ROUTES.COURSES} class="hover:text-primary transition-colors font-semibold text-gray-900">Ver todos los cursos</a>
        <a href="#" class="hover:text-primary transition-colors">Desarrollo web</a>
        <a href="#" class="hover:text-primary transition-colors">Data</a>
        <a href="#" class="hover:text-primary transition-colors">Diseño</a>
        <a href="#" class="hover:text-primary transition-colors">Management</a>
        <a href="#" class="hover:text-primary transition-colors">Negocios</a>
        <a href="#" class="hover:text-primary transition-colors">Marketing</a>
      </div>
    </details>
    
    <a href={ROUTES.BENEFITS} class="hover:text-primary transition-colors">Beneficios</a>
    <a href={ROUTES.COMMUNITY} class="hover:text-primary transition-colors">Comunidad</a>
    <a href={ROUTES.RESOURCES} class="hover:text-primary transition-colors">Recursos</a>
    <a href={ROUTES.ABOUT} class="hover:text-primary transition-colors">Nosotros</a>
  </nav>
</aside>

<script>
  const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");
  const mobileMenu = document.getElementById("mobile-menu");
  const openMenuBtn = document.getElementById("open-menu");
  const closeMenuBtn = document.getElementById("close-menu");

  function toggleMenu(show: boolean) {
    if (show) {
      mobileMenuOverlay?.classList.remove("opacity-0", "invisible");
      mobileMenuOverlay?.classList.add("opacity-100", "visible");
      mobileMenu?.classList.remove("translate-x-full");
      document.body.style.overflow = "hidden"; // Prevent scrolling
    } else {
      mobileMenuOverlay?.classList.remove("opacity-100", "visible");
      mobileMenuOverlay?.classList.add("opacity-0", "invisible");
      mobileMenu?.classList.add("translate-x-full");
      document.body.style.overflow = "auto";
    }
  }

  // Use event delegation or check for element existence before attaching
  openMenuBtn?.addEventListener("click", () => toggleMenu(true));
  closeMenuBtn?.addEventListener("click", () => toggleMenu(false));
  mobileMenuOverlay?.addEventListener("click", () => toggleMenu(false));
  
  // Also close menu on astro view transitions
  document.addEventListener('astro:after-swap', () => {
    toggleMenu(false);
  });
</script>

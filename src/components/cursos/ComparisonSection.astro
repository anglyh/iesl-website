---
import Section from "../ui/Section.astro";
import InfoBadge from "../ui/InfoBadge.astro";
import { Icon } from "astro-icon/components";
import { comparison } from "../../data/cursos.data";
---

<Section class="bg-gray-50/50">
  <!-- Encabezado centrado -->
  <div class="text-center max-w-2xl mx-auto mb-14">
    <InfoBadge text="La diferencia IESL" />
    <h2 class="font-bold text-gray-900 tracking-tight mb-4">
      {comparison.title}
    </h2>
    <p class="text-gray-600 inline-block">
      {comparison.description}
    </p>
  </div>

  <!-- Columnas comparativas -->
  <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">

    <!-- Columna: Otras instituciones (izquierda, sin borde especial) -->
    <div class="bg-white rounded-3xl p-6 border border-primary/40">
      <h4 class="font-bold text-gray-500 mb-6 font-poppins">
        {comparison.others.label}
      </h4>
      <ul class="space-y-4">
        {comparison.others.items.map((item) => (
          <li class="flex items-center gap-3 text-gray-500 font-inter">
            <Icon
              name="material-symbols:close-rounded"
              class="text-gray-400 text-xl shrink-0"
            />
            {item}
          </li>
        ))}
      </ul>
    </div>

    <!-- Columna: IESL Institute (derecha, destacada con borde primary) -->
    <div class="bg-primary/5 rounded-3xl p-6 border-2 border-primary/40">
      <h4 class="font-bold text-primary mb-6 font-poppins">
        {comparison.iesl.label}
      </h4>
      <ul class="space-y-4">
        {comparison.iesl.items.map((item) => (
          <li class="flex items-center gap-3 text-gray-700 font-inter font-medium">
            <Icon
              name="lucide:circle-check-big"
              class="text-primary text-xl shrink-0"
            />
            {item}
          </li>
        ))}
      </ul>
    </div>

  </div>
</Section>

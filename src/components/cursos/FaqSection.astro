---
import Section from "../ui/Section.astro";
import { Icon } from "astro-icon/components";
import { faqs } from "../../data/cursos.data";
---

<Section>
  <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
    <div class="">
      <h2 class="font-bold text-gray-900 mb-6 tracking-tight leading-tight">
        Preguntas<br />frecuentes
      </h2>
      <p class="text-gray-600 mb-6 font-medium">
        ¿Todavía tienes dudas? Escribenos a
        <a
          href="mailto:hola@ieslinstitute.com"
          class="text-primary font-bold hover:underline flex items-center gap-2"
        >
          hola@ieslinstitute.com
        </a>
      </p>
    </div>

    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group bg-white rounded-3xl border-2 border-primary/20 open:border-primary/60">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-gray-900 list-none [&::-webkit-details-marker]:hidden group-open:text-primary transition-global">
              <span class="pr-8 select-none">{faq.question}</span>
              <Icon
                name="tabler:chevron-down"
                class="transition-global group-open:rotate-180 text-xl md:text-2xl shrink-0"
              />
            </summary>
            <p class="px-6 pb-6 text-gray-600">
              {faq.answer}
            </p>
          </details>
        ))
      }
    </div>
  </div>
</Section>

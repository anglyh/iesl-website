---
import Button from "../ui/Button.astro";
import type { IconName } from "../../types/icons";
import "intl-tel-input/styles";

interface Props {
  submitText: string;
  privacyNote: string;
  buttonIcon?: IconName;
}

const {
  submitText,
  privacyNote,
  buttonIcon = "tabler:send",
} = Astro.props;
---
<script>
  import intlTelInput from "intl-tel-input";

  const phoneInput = document.querySelector("#phone") as HTMLInputElement | null;
  let iti: ReturnType<typeof intlTelInput> | null = null;

  if (phoneInput) {
    iti = intlTelInput(phoneInput, {
      initialCountry: "auto",
      geoIpLookup(callback) {
        fetch("https://ipapi.co/json")
          .then((res) => res.json())
          .then((data) => callback(data.country_code))
          .catch(() => callback("ar"));
      },
      loadUtils: () => import("intl-tel-input/utils"),
    });
  }

  const form = document.querySelector<HTMLFormElement>("#contact-form");
  const submitBtn = document.querySelector<HTMLButtonElement>("#contact-submit");
  const statusMsg = document.querySelector<HTMLElement>("#form-status");

  function setStatus(type: "success" | "error" | "loading" | "", message: string) {
    if (!statusMsg) return;
    statusMsg.textContent = message;
    statusMsg.className = "form-status";
    if (type) statusMsg.classList.add(`form-status--${type}`);
    statusMsg.hidden = !message;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const nombre   = (document.querySelector<HTMLInputElement>("#nombre")?.value ?? "").trim();
    const apellido = (document.querySelector<HTMLInputElement>("#apellido")?.value ?? "").trim();
    const email    = (document.querySelector<HTMLInputElement>("#email")?.value ?? "").trim();
    const telefono = iti ? iti.getNumber() : (phoneInput?.value ?? "").trim();

    if (!nombre || !apellido || !email || !telefono) {
      setStatus("error", "Por favor, completá todos los campos requeridos.");
      return;
    }

    setStatus("loading", "Enviando tu mensaje…");
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch("https://api.ieslinstitute.com/mailer.php", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ nombre, apellido, email, telefono }),
      });

      const data: { status: string; message: string } = await res.json();

      if (data.status === "success") {
        setStatus("success", data.message || "¡Mensaje enviado con éxito! Nos pondremos en contacto pronto.");
        form.reset();
      } else {
        setStatus("error", data.message || "Ocurrió un error. Por favor intentá de nuevo.");
      }
    } catch {
      setStatus("error", "No se pudo conectar con el servidor. Verificá tu conexión e intentá de nuevo.");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

<form id="contact-form" class="space-y-4" novalidate>
  <div>
    <label for="nombre" class="block font-bold text-gray-700 mb-1.5 ml-1 tracking-wider">Nombre*</label>
    <input
      id="nombre"
      name="nombre"
      type="text"
      placeholder="Juan"
      autocomplete="given-name"
      required
      class="w-full px-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-gray-50"
    />
  </div>
  <div>
    <label for="apellido" class="block font-bold text-gray-700 mb-1.5 ml-1 tracking-wider">Apellido*</label>
    <input
      id="apellido"
      name="apellido"
      type="text"
      placeholder="Perez"
      autocomplete="family-name"
      required
      class="w-full px-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-gray-50"
    />
  </div>

  <div class="flex flex-col gap-4">
    <div class="w-full">
      <label for="phone" class="block font-bold text-gray-700 mb-1.5 ml-1 tracking-wider">Teléfono*</label>
      <input
        id="phone"
        name="telefono"
        type="tel"
        autocomplete="tel"
        required
        class="w-full px-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-gray-50"
      />
    </div>

    <div>
      <label for="email" class="block font-bold text-gray-700 mb-1.5 ml-1 tracking-wider">Email*</label>
      <input
        id="email"
        name="email"
        type="email"
        placeholder="tucorreo@ejemplo.com"
        autocomplete="email"
        required
        class="w-full px-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-gray-50"
      />
    </div>
  </div>

  <!-- Status message -->
  <p id="form-status" class="form-status" hidden aria-live="polite"></p>

  <Button
    id="contact-submit"
    variant="primary"
    class="w-full mx-auto font-poppins mt-8"
    type="submit"
    icon={buttonIcon}
  >
    {submitText}
  </Button>
  <span class="text-center text-gray-400 mt-6 block text-sm">
    {privacyNote}
  </span>
</form>

<style is:global>
  .iti {
    --iti-path-flags-1x: url("https://cdn.jsdelivr.net/npm/intl-tel-input@26.9.1/build/img/flags.webp");
    --iti-path-flags-2x: url("https://cdn.jsdelivr.net/npm/intl-tel-input@26.9.1/build/img/flags@2x.webp");
    --iti-path-globe-1x: url("https://cdn.jsdelivr.net/npm/intl-tel-input@26.9.1/build/img/globe.webp");
    --iti-path-globe-2x: url("https://cdn.jsdelivr.net/npm/intl-tel-input@26.9.1/build/img/globe@2x.webp");
    width: 100% !important;
  }

  /* Form status feedback */
  .form-status {
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.9rem;
    text-align: center;
    transition: all 300ms ease;
  }
  .form-status--loading {
    background-color: #f0fafa;
    color: #2AB3BA;
    border: 1px solid #2AB3BA44;
  }
  .form-status--success {
    background-color: #f0faf5;
    color: #15803d;
    border: 1px solid #15803d44;
  }
  .form-status--error {
    background-color: #fff0f2;
    color: #d62942;
    border: 1px solid #d6294244;
  }
</style>
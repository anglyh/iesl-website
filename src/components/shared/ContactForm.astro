---
import Button from "../ui/Button.astro";
import type { IconName } from "../../types/icons";
import "intl-tel-input/styles";

interface Props {
  submitText: string;
  privacyNote: string;
  buttonIcon?: IconName;
}

const {
  submitText,
  privacyNote,
  buttonIcon = "tabler:send",
} = Astro.props;


---
<script>
  import intlTelInput from "intl-tel-input";
  const input = document.querySelector("#phone")
  if (input) {
    intlTelInput(input as HTMLInputElement, {
      initialCountry: "auto",
      geoIpLookup: function(callback) {
        fetch("https://ipapi.co/json")
          .then((res) => res.json())
          .then((data) => callback(data.country_code))
          .catch(() => callback("ar"));
      },
      loadUtils: () => import("intl-tel-input/utils"),
    });
  }
</script>

<form class="space-y-4">
  <div>
    <label class="block font-bold text-gray-700 mb-1.5 ml-1 tracking-wider">Nombre*</label>
    <input
      type="text"
      placeholder="Juan"
      class="w-full px-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-gray-50"
    />
  </div>
  <div>
    <label class="block font-bold text-gray-700 mb-1.5 ml-1 tracking-wider">Apellido*</label>
    <input
      type="text"
      placeholder="Perez"
      class="w-full px-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-gray-50"
    />
  </div>
  
  <div class="flex flex-col gap-4">
    <div class="w-full">
    <label class="block font-bold text-gray-700 mb-1.5 ml-1 tracking-wider">Teléfono*</label>
      <input type="tel" autocomplete="tel" id="phone" class="w-full px-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-gray-50" />
    </div>  
    
    <div>
      <label class="block font-bold text-gray-700 mb-1.5 ml-1 tracking-wider">Email*</label>
      <input
        type="email"
        placeholder="tucorreo@ejemplo.com"
        class="w-full px-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-gray-50"
      />
    </div>
  </div>

  <Button
    variant="primary"
    class="w-full mx-auto font-poppins mt-8"
    type="submit"
    icon={buttonIcon}
  >
    {submitText}
  </Button>
  <span class="text-center text-gray-400 mt-6 block text-sm">
    {privacyNote}
  </span>
</form>

<style is:global>
  .iti {
    --iti-path-flags-1x: url("https://cdn.jsdelivr.net/npm/intl-tel-input@26.9.1/build/img/flags.webp");
    --iti-path-flags-2x: url("https://cdn.jsdelivr.net/npm/intl-tel-input@26.9.1/build/img/flags@2x.webp");
    --iti-path-globe-1x: url("https://cdn.jsdelivr.net/npm/intl-tel-input@26.9.1/build/img/globe.webp");
    --iti-path-globe-2x: url("https://cdn.jsdelivr.net/npm/intl-tel-input@26.9.1/build/img/globe@2x.webp");
    width: 100% !important;
  }
</style>
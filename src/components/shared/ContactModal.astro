---
import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';

interface Props {
  buttonText: string;
}

const { buttonText } = Astro.props;
---

<Button variant="secondary" id="open-dialog" type="button">
  {buttonText}
</Button>

<dialog class="bg-white rounded-4xl p-8 backdrop:bg-black/60 shadow-2xl m-auto max-w-lg w-full" id="contact-dialog">
  <div class="relative">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-3xl font-bold text-gray-900 mb-2">Unirme a la comunidad</h3>
      <button class="hover:text-gray-900 bg-slate-100 rounded-full p-2 cursor-pointer" id="close-dialog">
        <Icon name="mdi:close" class="w-6 h-6" />
      </button>
    </div>
    <p class="text-gray-600 mb-6">Te enviaremos el link de acceso a tu correo.</p>
  
    <form class="flex flex-col gap-4">
      <div>
        <label for="name" class="block font-bold text-gray-700 mb-1.5 ml-1">Nombre</label>
        <input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:border-primary bg-gray-50" placeholder="Ej: Juan">
      </div>
      <div>
        <label for="email" class="block font-bold text-gray-700 mb-1.5 ml-1">Email</label>
        <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:border-primary bg-gray-50" placeholder="juan@ejemplo.com">
      </div>
      
      <Button type="submit" class="mt-4 w-full justify-center">
        Recibir acceso
      </Button>
    </form>
  </div>
</dialog>

<script>
  // Encontramos los elementos
  const dialog = document.querySelector("#contact-dialog") as HTMLDialogElement;
  const button = document.querySelector("#open-dialog") as HTMLButtonElement;
  const closeDialogButton = document.querySelector("#close-dialog") as HTMLButtonElement;

  // Abrir modal
  button.addEventListener("click", () => {
    dialog.showModal();
  });

  // Cerrar modal al hacer clic en el fondo oscuro
  dialog.addEventListener("click", (e) => {
    // Calculamos las dimensiones de la caja blanca
    const dialogDimensions = dialog.getBoundingClientRect();
    
    // Si el clic ocurrió fuera de los límites de la caja blanca (es decir, en el fondo oscuro)
    if (
      e.clientX < dialogDimensions.left ||
      e.clientX > dialogDimensions.right ||
      e.clientY < dialogDimensions.top ||
      e.clientY > dialogDimensions.bottom
    ) {
      dialog.close();
    }
  });

  closeDialogButton.addEventListener("click", () => {
    dialog.close();
  });
</script>
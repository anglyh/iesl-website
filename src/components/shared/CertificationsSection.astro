---
import Section from "../ui/Section.astro";
import InfoBadge from "../ui/InfoBadge.astro";
import CertificationBadge from "../ui/CertificationBadge.astro";
---

<Section>
  <div class="text-center max-w-2xl mx-auto mb-20">
    <InfoBadge text="Certificados" />
    <h2 class="font-bold text-gray-900 tracking-tight text-3xl md:text-4xl mt-3">
      Nuestros niveles de certificación
    </h2>
  </div>
  <div
    class="flex flex-col xl:flex-row justify-center items-center gap-x-24 gap-y-8"
  >
    <CertificationBadge level="professional" />
    <CertificationBadge level="specialist" />
    <CertificationBadge level="expert" />
  </div>
</Section>

---
import Section from "../ui/Section.astro";
import InfoBadge from "../ui/InfoBadge.astro";
import EventCard from "../ui/EventCard.astro";
import { events } from "../../data/comunidad.data";
import { Icon } from "astro-icon/components";
---

<Section class="bg-gray-50/50">
  <div class="grid lg:grid-cols-2 gap-16 items-start">
    <div>
      <InfoBadge text={events.badge} />
      <h2 class="font-bold text-gray-900 mb-6 tracking-tight leading-tight">
        {events.title}
      </h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        {events.description}
      </p>
      <div class="flex items-center gap-3">
        <Icon name="akar-icons:calendar" class="text-primary text-2xl"/>
        <p class="text-gray-600 leading-relaxed">{events.note}</p>
      </div>
    </div>
    <div class="flex flex-col gap-4">
      {events.events.map((event) => (
        <EventCard
          title={event.title}
          description={event.description}
          date={event.date.toISOString()}
        />
      ))}
    </div>
  </div>
</Section>

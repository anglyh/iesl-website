---
import Section from "../ui/Section.astro";
import InfoBadge from "../ui/InfoBadge.astro";
import ConnectCard from "../ui/ConnectCard.astro";
import Button from "../ui/Button.astro";
import { connect } from "../../data/comunidad.data";
import ContactModal from "../shared/ContactModal.astro";
---

<Section class="bg-gray-50/50">
  <div class="text-center max-w-2xl mx-auto mb-16">
    <InfoBadge text={connect.badge} />
    <h2 class="font-bold text-gray-900 mb-4 tracking-tight">
      {connect.title}
    </h2>
    <p class="text-gray-600 font-medium">
      {connect.description}
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-8 mb-12 max-w-7xl mx-auto">
    {connect.cards.map((card) => (
      <ConnectCard
        title={card.title}
        description={card.description}
        img={card.image}
      />
    ))}
  </div>

  <div class="flex justify-center">
    <ContactModal buttonText={connect.cta.text} />
  </div>
</Section>

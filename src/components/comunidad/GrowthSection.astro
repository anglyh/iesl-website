---
import Section from "../ui/Section.astro";
import InfoBadge from "../ui/InfoBadge.astro";
import { Icon } from "astro-icon/components";
import { growth } from "../../data/comunidad.data";
import SmartImage from "../ui/SmartImage.astro";
---

<Section>
  <div class="grid lg:grid-cols-2 gap-16 items-center">
    <div class="relative w-full max-w-md mx-auto lg:mx-0">
      <div class="bg-gray-200 rounded-full flex items-center justify-center text-gray-400 shadow-lg">
        <SmartImage src={growth.image} alt="" class="w-full h-full object-cover" />
      </div>
    </div>

    <div>
      <InfoBadge text={growth.badge} />
      <h2 class="font-bold text-gray-900 mb-6 tracking-tight leading-tight">
        {growth.title}
      </h2>
      <p class="text-gray-600 mb-10 leading-relaxed font-medium">
        {growth.description}
      </p>
      <ul class="space-y-5">
        {growth.items.map((item) => (
          <li class="flex items-start gap-4">
            <div class="p-2 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
              <Icon name={item.icon} size={24} />
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-gray-800 font-bold">
                {item.title}
              </span>
              <p class="text-gray-600 text-sm leading-relaxed">{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Section>

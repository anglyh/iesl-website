---
import Section from "../ui/Section.astro";
import Glow from "../ui/Glow.astro";
import { contactForm } from "../../data/comunidad.data";
import ContactForm from "../shared/ContactForm.astro";
---

<Section class="relative" id="contacto">
  <Glow
    position="top-0 right-0"
    size="w-[800px] h-[400px]"
  />
  <Glow
    position="bottom-0 right-1/4"
    size="w-[1200px] h-[400px]"
  />

  <div class="grid lg:grid-cols-2 gap-16">
    <!-- Columna izquierda -->
    <div class="w-full lg:w-3/5">
      <h2 class="font-bold text-gray-900 mb-8 text-3xl md:text-5xl tracking-tight leading-tight text-balance">
        {contactForm.title.static}
        <span class="text-primary inline-block">{contactForm.title.highlight}</span>
      </h2>
      <p class="text-gray-600 mb-8 leading-relaxed text-lg">
        {contactForm.description}
      </p>
    </div>

    <!-- Columna derecha -->
    <div
      class="bg-white rounded-4xl p-6 sm:p-10 border-2 border-primary/50 max-w-xl mx-auto lg:ml-auto w-full relative overflow-hidden"
    >
      <!-- Título del formulario -->
      <div class="text-center mb-8 relative">
        <h3 class="font-bold text-gray-900 text-xl md:text-3xl mb-6">
          {contactForm.formTitle.static}
          <span class="text-primary inline-block">{contactForm.formTitle.highlight}</span>
        </h3>
        <p class="text-gray-500 font-medium">
          {contactForm.formDescription}
        </p>
      </div>

      <!-- Formulario -->
      <ContactForm
        submitText={contactForm.submitText}
        privacyNote={contactForm.privacyNote}
      />
    </div>
  </div>
</Section>

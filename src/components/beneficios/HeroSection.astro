---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
import Glow from "../ui/Glow.astro";
import { hero } from "../../data/beneficios.data";
import SmartImage from "../ui/SmartImage.astro";
---

<Section class="relative overflow-hidden">
  <Glow
    position="top-1/2 left-0"
    color="secondary"
    size="w-[600px] h-[200px]"
    class="-translate-y-1/4"
  />
  
  <div class="grid lg:grid-cols-2 gap-12 items-center">
    <div class="max-w-xl">
      <div
        class="inline-flex items-center gap-2 px-5 py-1.5 text-sm rounded-full mb-6 border border-primary bg-white "
      >
        {hero.badge}
      </div>
      <h1 class="leading-[1.1] font-bold text-gray-900 mb-6 tracking-tight">
        {hero.title}
      </h1>
      <p class="text-gray-600 mb-10 leading-relaxed font-medium">
        {hero.description}
      </p>
      <Button href={hero.cta.href} icon="fluent:arrow-right-16-filled">
        {hero.cta.text}
      </Button>
    </div>

    <div class="relative lg:ml-auto w-full max-w-lg mt-10 lg:mt-0 m-auto flex gap-6 justify-center">
      <div class="w-full h-100 bg-gray-200 rounded-3xl shadow-xl flex items-center justify-center text-gray-400 text-sm overflow-hidden">
        <SmartImage src={hero.images[1]} alt="" class="w-full h-full object-cover" />
      </div>
      <div class="w-full h-100 bg-gray-200 rounded-3xl shadow-xl flex items-center justify-center text-gray-400 text-sm overflow-hidden">
        <SmartImage src={hero.images[0]} alt="" class="w-full h-full object-cover" />
      </div>
    </div>
  </div>
</Section>

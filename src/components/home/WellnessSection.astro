---
import Section from "../ui/Section.astro";
import InfoBadge from "../ui/InfoBadge.astro";
import Button from "../ui/Button.astro";
import { wellness } from "../../data/inicio.data";
import ImageWithBadge from "../ui/ImageWithBadge.astro";
import Glow from "../ui/Glow.astro";
---

<Section class="bg-gray-50 overflow-hidden relative">
  <Glow 
    color="bg-teal-50/50"
    size="w-[400px] h-[400px]"
    position="top-0 right-0"
    blur="blur-[80px]"
    class="-translate-y-1/2 translate-x-1/2"
  />
  <div class="grid lg:grid-cols-2 gap-16 items-center">
    <div class="order-1">
      <InfoBadge text={wellness.badge} />
      <h2 class="font-bold text-gray-900 mb-6 tracking-tight leading-tight sm:w-4/5">
        {wellness.title.static}<br /><span class="text-primary"
          >{wellness.title.highlight}</span
        >
      </h2>
      <p class="text-gray-600 mb-10 leading-relaxed font-medium">
        {wellness.description}
      </p>
      <Button href={wellness.cta.href} icon="fluent:arrow-right-16-filled" variant="secondary">
        {wellness.cta.text}
      </Button>
    </div>

    <div
      class="flex justify-center min-h-130 items-center relative w-full h-full mx-auto px-4 order-2"
      id="wellness-slider"
    >
      {wellness.slides.map((badges, index) => (
        <div class={`wellness-slide transition-opacity duration-1000 ease-in-out ${index === 0 ? 'absolute inset-0 opacity-100 z-10' : 'absolute inset-0 opacity-0 z-0 pointer-events-none'}`}>
          <ImageWithBadge
            image={badges[0].image || ""}
            badgeTitle={badges[0].title}
            badgeDescription={badges[0].description}
            badgeIcon={badges[0].icon}
            badgeColor={badges[0].color}
            class="absolute right-1/2 top-0 -mr-[7.2rem] sm:-mr-20 lg:max-xl:-mr-17.5 w-64 sm:w-80 lg:max-xl:w-70 h-72 sm:h-84 z-10"
            badgePosition="top-right"
          />

          <ImageWithBadge
            image={badges[1].image || ""}
            badgeTitle={badges[1].title}
            badgeDescription={badges[1].description}
            badgeIcon={badges[1].icon}
            badgeColor={badges[1].color}
            class="absolute left-1/2 -bottom-10 sm:bottom-0 -ml-[7.2rem] sm:-ml-20 lg:max-xl:-ml-17.5 w-64 sm:w-80 lg:max-xl:w-70 h-72 sm:h-84"
            badgePosition="top-left"
          />
        </div>
      ))}
    </div>
  </div>
</Section>

<script>
  function initWellnessSlider() {
    const slider = document.getElementById('wellness-slider');
    if (!slider) return;
    
    // Evitar acumulacion de intervalos en vistas SPA de Astro
    if ((window as any).wellnessSliderInterval) {
      clearInterval((window as any).wellnessSliderInterval);
    }
    
    const slides = slider.querySelectorAll('.wellness-slide');
    if (slides.length <= 1) return;
    
    let currentIndex = 0;
    
    (window as any).wellnessSliderInterval = setInterval(() => {
      // Ocultar actual
      const currentSlide = slides[currentIndex] as HTMLElement;
      currentSlide.classList.remove('opacity-100', 'z-10');
      currentSlide.classList.add('opacity-0', 'z-0', 'pointer-events-none');
      
      // Pasar al siguiente
      currentIndex = (currentIndex + 1) % slides.length;
      
      // Mostrar siguiente
      const nextSlide = slides[currentIndex] as HTMLElement;
      nextSlide.classList.remove('opacity-0', 'z-0', 'pointer-events-none');
      nextSlide.classList.add('opacity-100', 'z-10');
    }, 3500); 
  }

  document.addEventListener('astro:page-load', initWellnessSlider);
  initWellnessSlider();
</script>

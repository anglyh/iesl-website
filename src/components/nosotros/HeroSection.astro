---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
import Glow from "../ui/Glow.astro";
import SmartImage from "../ui/SmartImage.astro";
import { hero } from "../../data/nosotros.data";
---

<Section class="relative overflow-hidden">
  <Glow
    position="top-30 -left-1/2"
    size="w-[100vw] h-[500px]"
    class="-translate-y-1/4"
  />

  <div class="grid lg:grid-cols-2 gap-12 items-center">
    <div class="max-w-xl">
      <div
        class="inline-flex items-center gap-2 px-5 py-1.5 text-sm rounded-full mb-6 border border-primary bg-white"
      >
        {hero.badge}
      </div>
      <h1 class="leading-[1.1] font-bold text-gray-900 mb-6 tracking-tight">
        {hero.title.static} <br />
        <span class="text-primary">{hero.title.highlight}</span>
      </h1>
      <p class="text-gray-600 mb-10 leading-relaxed font-medium">
        {hero.description}
      </p>
      <Button
        icon="fluent:arrow-right-16-filled"
        href={hero.cta.href}
      >
        {hero.cta.text}
      </Button>
    </div>

    <div class="relative lg:ml-auto w-full max-w-lg mt-10 lg:mt-0 m-auto">
      <SmartImage
        alt="Equipo IESL"
        class="w-full h-80 object-cover rounded-3xl shadow-xl"
        src={hero.image}
      />
    </div>
  </div>
</Section>
